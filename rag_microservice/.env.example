# Google API Key is required for the embedding model (models/gemini-embedding-001)
GOOGLE_API_KEY="your_google_api_key_here"

# Pinecone API Key is required for the vector database search
PINECONE_API_KEY="your_pinecone_api_key_here"

# Groq API Key is required for the Llama 3.1 generation model
GROQ_API_KEY="your_groq_api_key_here"

# Cohere API Key is required for the rerank-v3.5 Reranking model
COHERE_API_KEY="your_cohere_api_key"